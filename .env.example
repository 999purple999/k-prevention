# ---- k-prevention environment ----
# Copy to .env for local development.  Never commit the real .env.

# Server-side secret used to:
#  - derive email_lookup = HMAC-SHA256(SERVER_SECRET, lower(email))  (deterministic, searchable)
#  - derive deterministic fake salts for unknown emails (anti user-enumeration)
#  - sign the session JWT
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SERVER_SECRET=change-me-to-a-32-byte-base64-secret

# Persistence backend: "sqlite" (local, node:sqlite) or "firestore" (Cloud Run).
STORE_BACKEND=sqlite

# SQLite database file (only used when STORE_BACKEND=sqlite).
SQLITE_PATH=./data/k-prevention.db

# Firestore (only used when STORE_BACKEND=firestore). On Cloud Run these are
# provided automatically via Application Default Credentials; set locally to test.
# GOOGLE_CLOUD_PROJECT=my-gcp-project
# FIRESTORE_DATABASE_ID=(default)

# HTTP port. Cloud Run injects PORT automatically.
PORT=8080
