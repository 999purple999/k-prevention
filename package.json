{
  "name": "k-prevention",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Simulatore Monte Carlo di flusso di cassa per liberi professionisti — cifrato end-to-end, deploy su Google Cloud Run.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -k -n server,vite -c blue,magenta \"npm:dev:server\" \"npm:dev:vite\"",
    "dev:server": "cross-env NODE_ENV=development node --watch server/index.js",
    "dev:vite": "vite",
    "build": "vite build",
    "build:demo": "cross-env VITE_DEMO=1 vite build --base ./ --outDir dist-demo",
    "preview:demo": "vite preview --outDir dist-demo --port 8090",
    "start": "node server/index.js",
    "seed": "node server/seed.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cookie": "^0.6.0",
    "express": "^4.21.2",
    "jose": "^5.9.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3"
  },
  "optionalDependencies": {
    "@google-cloud/firestore": "^7.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
